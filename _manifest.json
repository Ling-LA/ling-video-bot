{
  "manifest_version": 2,
  "id": "github.ling-la.ling-video-bot",
  "version": "2.1.0",
  "name": "视频解析Bot",
  "description": "自动解析抖音和 B站分享链接，发送原视频并结合视觉识别生成人设风格点评。",
  "author": {
    "name": "Ling-LA",
    "url": "https://github.com/Ling-LA"
  },
  "license": "MIT",
  "urls": {
    "repository": "https://github.com/Ling-LA/ling-video-bot",
    "homepage": "https://github.com/Ling-LA/ling-video-bot",
    "documentation": "https://github.com/Ling-LA/ling-video-bot/blob/master/README.md",
    "issues": "https://github.com/Ling-LA/ling-video-bot/issues"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [
    {
      "type": "python_package",
      "name": "aiohttp",
      "version_spec": ">=3.0"
    },
    {
      "type": "python_package",
      "name": "aiofiles",
      "version_spec": ">=25.1.0"
    },
    {
      "type": "python_package",
      "name": "bilibili-api-python",
      "version_spec": ">=17.4.1"
    },
    {
      "type": "python_package",
      "name": "curl-cffi",
      "version_spec": ">=0.15.0"
    },
    {
      "type": "python_package",
      "name": "yt-dlp",
      "version_spec": ">=2026.3.17"
    }
  ],
  "plugin_type": "media",
  "capabilities": [
    "config.get",
    "send.custom",
    "send.text"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "supported_locales": ["zh-CN"]
  }
}
