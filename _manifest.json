{
  "manifest_version": 2,
  "id": "ling.video-bot",
  "version": "1.0.0",
  "name": "视频解析Bot",
  "description": "自动解析抖音/B站视频链接和分享卡片，发送高清原视频+AI视觉分析+人设风格点评",
  "author": {
    "name": "ling",
    "url": "https://github.com/Ling-LA"
  },
  "license": "MIT",
  "urls": {
    "repository": "https://github.com/Ling-LA/ling-video-bot"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [
    {"type": "python_package", "name": "aiohttp", "version_spec": ">=3.0"},
    {"type": "python_package", "name": "aiofiles", "version_spec": ">=25.1.0"},
    {"type": "python_package", "name": "bilibili-api-python", "version_spec": ">=17.4.1"},
    {"type": "python_package", "name": "Pillow", "version_spec": ">=10.0"}
  ],
  "capabilities": ["send.text", "send.custom"],
  "i18n": {"default_locale": "zh-CN"}
}
